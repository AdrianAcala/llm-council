# OpenRouter API Key (get from https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-v1-...

# LLM Council Configuration
# Comma-separated list of model identifiers
COUNCIL_MODELS=openai/gpt-5.1,google/gemini-3-pro-preview,anthropic/claude-sonnet-4.5

# Chairman model (synthesizes final response)
CHAIRMAN_MODEL=google/gemini-3-pro-preview

# Title generation model (generates conversation titles - fast/cheap model preferred)
# Defaults to kimi-k2.5:cloud if not set
TITLE_MODEL=kimi-k2.5:cloud
