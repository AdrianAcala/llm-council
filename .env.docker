# Docker Environment Configuration for LLM Council
# Copy this to .env and fill in your values

# Required: OpenRouter API Key (get from https://openrouter.ai/)
OPENROUTER_API_KEY=your-api-key-here

# Optional: Council models (defaults shown)
COUNCIL_MODELS=openai/gpt-5.1,google/gemini-3-pro-preview,anthropic/claude-sonnet-4.5

# Optional: Chairman model (defaults shown)
CHAIRMAN_MODEL=google/gemini-3-pro-preview

# Frontend API configuration
# Use http://localhost:8001 for local access, or http://backend:8001 for inter-container
VITE_API_BASE=http://localhost:8001
